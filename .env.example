# Database (PostgreSQL + pgvector)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=codebaseqa
DB_USERNAME=postgres
DB_PASSWORD=postgres

# Redis (Upstash or local)
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-super-secret-key-minimum-32-characters-long-change-this-in-production

# GitHub OAuth
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_REDIRECT_URI=http://localhost:8080/api/auth/github/callback

# Google Gemini
GEMINI_API_KEY=your_gemini_api_key

# AWS (leave empty for now, will configure when needed in Task 1.4)
AWS_REGION=us-east-1
SQS_QUEUE_URL=
SQS_DLQ_URL=

# App
FRONTEND_URL=http://localhost:5173
INDEXING_TEMP_DIR=/tmp/codebase-qa
